# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vigilai?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/vigilai?schema=public"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub Integration (for automated PRs)
GITHUB_APP_ID=""
GITHUB_PRIVATE_KEY=""

# Email Service (Optional - for password reset and notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@vigilai.com"

# WebSocket (Optional - defaults to same origin)
NEXT_PUBLIC_WS_URL=""

# Redis (Optional - for caching)
REDIS_URL=""

# Monitoring (Optional)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
